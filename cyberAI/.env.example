# CyberAI Configuration Template
# Copy this file to .env and fill in your values

# Target Configuration
TARGET_URL=https://example.com

# Proxy Settings
PROXY_ENABLED=false
PROXY_SOURCE_URL=https://free-proxy-list.net/
PROXY_CACHE_TTL_MINUTES=30

# Captcha Settings (optional - for captcha bypass)
CAPTCHA_API_KEY=
CAPTCHA_SERVICE=2captcha  # 2captcha or anticaptcha

# Browser Settings
HEADLESS=true
BROWSER_TIMEOUT_MS=30000
USER_AGENT_ROTATION=true

# Execution Settings
MAX_WORKERS=4
REQUEST_DELAY_MS=200
MAX_REQUESTS_PER_ENDPOINT=10
RATE_LIMIT_WINDOW_SECONDS=10

# LLM / RAG (see cyberAI/llm/README_RAG.md)
LLM_ENABLED=false

# OpenAI-compatible API: official DeepSeek or OpenRouter (same client; keys in project root .env)
# DEEPSEEK_API_KEY=sk-...
# Or use OpenRouter key instead of the line above:
# OPENROUTER_API_KEY=sk-or-v1-...

# Base URL (default: https://api.deepseek.com). OpenRouter example:
# DEEPSEEK_BASE_URL=https://openrouter.ai/api

# Model id for your provider (OpenRouter example):
# DEEPSEEK_MODEL=deepseek/deepseek-r1

# Optional OpenRouter analytics headers:
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_X_TITLE=Cyber Hunt AI

# Role Accounts for Multi-Role Testing
# JSON array of account objects with role, username, password, and optional mfa_secret
# Example: [{"role": "admin", "username": "admin@example.com", "password": "adminpass"}, {"role": "user", "username": "user@example.com", "password": "userpass"}]
ROLE_ACCOUNTS=[]

# Output Settings
OUTPUT_DIR=outputs

# Robots.txt Handling
IGNORE_ROBOTS=false

# Dry Run Mode (simulate without making real requests)
DRY_RUN=false

# Logging
LOG_LEVEL=INFO
VERBOSE=false
